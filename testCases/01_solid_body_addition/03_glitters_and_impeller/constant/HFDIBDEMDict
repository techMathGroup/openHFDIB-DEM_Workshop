FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      HFDIBDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
bodyNames ("impeller_scaled" "glitter");

interpolationSchemes
{
  U cell;
}

surfaceThreshold    1e-4;
stepDEM     1;
geometricD (1 1 1);
recordSimulation true;
recordFirstTimeStep false;
nSolidsInDomain -1;       //Sets Upper Limit On Number Of Particles In Domain if not spcecified sets to 1000 by default


outputSetup
{
    basic true;
    iB  false;
    DEM false;
    addModel true;
    parallelDEM false;
}

// -- required for repeatRandomPosition addModel ---------------(START)-
DEM
{
    // LcCoeff 4.0;
    // LcCoeff 0.55;
    // rotationModel chen2012;
	// rotationModel mindlin1953
    materials
    {
        particle
        {
            Y       1;
            nu      0;
            mu      0;
            adhN    0;
            eps     1;
        }

        wall
        {
            Y       1;
            nu      0;
            mu      0;
            adhN    0;
            eps     1;
        }
    }

    collisionPatches
    {

    }
}

virtualMesh
{
    level 2;
    charCellSize 0.001;
}
// -- required for repeatRandomPosition addModel -----------------(END)-

impeller_scaled
{
    staticBody;

    rho         rho [1 -3 0 0 0 0 0] 1;
    material particle;
    
    bodyGeom nonConvex;
    updateTorque false;
    sdBasedLambda false;
    interfaceSpan 1.0;
    startSynced false;
    refineBuffers 2;
    timesToSetStatic 1; //number of timeSteps in contact with wall/static body to set body as static. Never when -1
    bodyAddition
    {
        addModel once;
        onceCoeffs{}
    }
    material particle;
}

glitter
{
    staticBody;

    rho         rho [1 -3 0 0 0 0 0] 1;
    material particle;
    
    bodyGeom convex;
    updateTorque false;
    sdBasedLambda false;
    interfaceSpan 1.0;
    startSynced false;
    refineBuffers 2;
    timesToSetStatic 1; //number of timeSteps in contact with wall/static body to set body as static. Never when -1
    //~ bodyAddition
    //~ {
        //~ addModel once;
        //~ onceCoeffs{}
    //~ }
    bodyAddition
    {
        addModel repeatRandomPosition;
        repeatRandomPositionCoeffs
        {
            addMode fieldBased;
 			fieldBasedCoeffs
 			{
 				fieldName lambda;
 				fieldValue 0.1;
 			}
            addDomain boundBox;
 			boundBoxCoeffs
 			{
 				minBound (-0.03 -0.03 -0.01);
 				maxBound (0.03 -0.02 0.01);
 			}
            scalingMode    noScaling;
 			noScalingCoeffs{}
            scalingMode    randomScaling;
            randomScalingCoeffs
            {
                minScale 0.5;
                maxScale 0.5;
            }
            rotationMode   randomRotation;
 			randomRotationCoeffs{}
        }
    }
    material particle;
}

