internalField   uniform (0 0 0);

boundaryField
{
    z1
    {
        type            zeroGradient;
    }
    z0
    {
        type            zeroGradient;
    }
    x1
    {
        type            zeroGradient;
    }
    x0
    {
        type            zeroGradient;
    }
    y0
    {
        type            zeroGradient;
    }
    y1
    {
        type            zeroGradient;
    }
}


